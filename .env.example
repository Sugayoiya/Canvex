# ╔══════════════════════════════════════════════════════════╗
# ║  Canvex — 唯一配置文件，修改后 docker compose up -d 即可  ║
# ╚══════════════════════════════════════════════════════════╝
# 使用方式: cp .env.example .env && 填入你的 API Key → docker compose up -d

# ────────────── PostgreSQL ──────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=canvex
POSTGRES_PORT=5432

# ────────────── Redis ──────────────
REDIS_PORT=6379

# ────────────── Application ──────────────
USE_SQLITE=false
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}
REDIS_URL=redis://redis:${REDIS_PORT}/0
CELERY_BROKER_URL=redis://redis:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://redis:${REDIS_PORT}/2

# ────────────── JWT ──────────────
SECRET_KEY=change-me-in-production-use-random-64-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ────────────── CORS ──────────────
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:80"]

# ────────────── AI Providers ──────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ────────────── File Storage ──────────────
UPLOAD_DIR=./uploads

# ────────────── Frontend ──────────────
FRONTEND_URL=http://localhost

# ────────────── Default Admin ──────────────
DEFAULT_ADMIN_EMAIL=admin@canvex.studio
DEFAULT_ADMIN_PASSWORD=Admin123!

# ────────────── NPM (Nginx Proxy Manager) ──────────────
NPM_EMAIL=admin@canvex.studio
NPM_PASSWORD=change-me
HTTP_PORT=80
HTTPS_PORT=443
NPM_ADMIN_PORT=81

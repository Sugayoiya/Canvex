  "typography": {
    "fontFamily": {
      "headline": "Space Grotesk",
      "body": "Manrope",
      "label": "Manrope",
      "mono": "Space Grotesk"
    },
    "scale": {
      "displayLg": { "size": 44, "weight": "700", "font": "Space Grotesk", "tracking": "-0.02em" },
      "displayMd": { "size": 36, "weight": "700", "font": "Space Grotesk", "tracking": "-0.02em" },
      "headlineLg": { "size": 28, "weight": "700", "font": "Space Grotesk", "tracking": "-0.01em" },
      "headlineMd": { "size": 24, "weight": "700", "font": "Space Grotesk" },
      "headlineSm": { "size": 20, "weight": "700", "font": "Space Grotesk" },
      "titleLg": { "size": 18, "weight": "600", "font": "Manrope" },
      "titleMd": { "size": 16, "weight": "600", "font": "Manrope" },
      "titleSm": { "size": 14, "weight": "600", "font": "Manrope" },
      "bodyLg": { "size": 14, "weight": "400", "font": "Manrope", "lineHeight": 1.6 },
      "bodyMd": { "size": 13, "weight": "400", "font": "Manrope", "lineHeight": 1.5 },
      "bodySm": { "size": 12, "weight": "400", "font": "Manrope", "lineHeight": 1.5 },
      "labelLg": { "size": 12, "weight": "700", "font": "Manrope", "tracking": "0.1em", "transform": "uppercase" },
      "labelMd": { "size": 10, "weight": "700", "font": "Space Grotesk", "tracking": "0.2em", "transform": "uppercase" },
      "labelSm": { "size": 9, "weight": "700", "font": "Space Grotesk", "tracking": "0.2em", "transform": "uppercase" },
      "metadata": { "size": 9, "weight": "400", "font": "Space Grotesk", "tracking": "0.1em" },
      "code": { "size": 12, "weight": "400", "font": "Space Grotesk", "lineHeight": 1.5 }
    }
  },

  "spacing": {
    "page": { "paddingX": 40, "paddingY": 40 },
    "card": { "padding": [24, 32] },
    "section": { "gap": 32 },
    "sidebarWidth": 256,
    "topBarHeight": 64,
    "gap": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24,
      "xl": 32,
      "xxl": 48
    }
  },

  "radii": {
    "none": 0,
    "sm": 4,
    "default": 6,
    "md": 8,
    "lg": 12,
    "xl": 16,
    "xxl": 20,
    "full": 9999
  },

  "iconography": {
    "library": "material-symbols-outlined",
    "variationSettings": "'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24",
    "sidebarIcons": {
      "workspace": "grid_view",
      "productions": "movie_filter",
      "team": "group",
      "aiEngine": "psychology",
      "archive": "inventory_2",
      "support": "help_outline",
      "settings": "tune"
    },
    "actionIcons": {
      "add": "add",
      "addCircle": "add_circle",
      "search": "search",
      "notifications": "notifications",
      "more": "more_horiz",
      "copy": "content_copy",
      "bolt": "bolt",
      "expandMore": "expand_more",
      "arrowForward": "arrow_forward",
      "edit": "edit",
      "delete": "delete",
      "link": "link",
      "verified": "verified_user",
      "layers": "layers",
      "sync": "sync",
      "upload": "arrow_upward"
    },
    "statusIcons": {
      "autoAwesome": "auto_awesome",
      "circle": "circle",
      "checkCircle": "check_circle",
      "warning": "warning",
      "error": "error"
    }
  },

  "motion": {
    "transitionFast": "150ms ease",
    "transitionDefault": "300ms ease",
    "transitionSlow": "500ms ease",
    "transitionVerySlow": "700ms ease",
    "hoverScale": 1.1,
    "activeScale": 0.98
  },

  "compatibility": {
    "phase04MappingNote": "Phase 04/05 canvas tokens remain valid for canvas workspace. Phase 06 extends them for dashboard/management pages. Key bridging: surface.primary=#2A2A2A maps to surface.containerHigh=#1A1A1A; text.primary=#E5E2E1 shared; typography fonts shared.",
    "canvasTokensPath": "../04-media-tools/designs/design-tokens.json"
  }
}

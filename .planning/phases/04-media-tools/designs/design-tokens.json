{
  "$schema": "design-tokens-v1",
  "description": "Canvas V4 Minimal — Design Tokens for Dark & Light themes",
  "source": "pencil-new.pen (Frame GVXke / Pm52C)",

  "themes": {
    "dark": {
      "canvas": {
        "background": "#131313",
        "gridDot": "#3c494e"
      },
      "surface": {
        "primary": "#2A2A2A",
        "secondary": "#353534",
        "elevated": "#201F1F",
        "overlay": "#1C1B1BDD",
        "popup": "#1C1B1B",
        "code": "#0E0E0E"
      },
      "text": {
        "primary": "#E5E2E1",
        "secondary": "#BBC9CF",
        "muted": "#859399",
        "placeholder": "#85939930",
        "disabled": "#85939960"
      },
      "border": {
        "default": "#3c494e20",
        "subtle": "#3c494e15",
        "faint": "#3c494e12",
        "focused": "#E5E2E130",
        "divider": "#3c494e40"
      },
      "interactive": {
        "buttonPrimary": "#E5E2E1",
        "buttonPrimaryText": "#131313",
        "buttonSecondary": "#2A2A2A",
        "buttonSecondaryText": "#BBC9CF",
        "activeHighlight": "#E5E2E115",
        "hoverHighlight": "#E5E2E110"
      },
      "shadow": {
        "sm": { "blur": 10, "color": "#00000040", "offsetY": 2 },
        "md": { "blur": 20, "color": "#00000040", "offsetY": 4 },
        "lg": { "blur": 30, "color": "#00000050", "offsetY": 6 },
        "xl": { "blur": 60, "color": "#00000060", "offsetY": 12 }
      }
    },

    "light": {
      "canvas": {
        "background": "#F5F5F5",
        "gridDot": "#D0D0D0"
      },
      "surface": {
        "primary": "#FFFFFF",
        "secondary": "#EBEBEB",
        "elevated": "#FFFFFF",
        "overlay": "#FFFFFFEE",
        "popup": "#FFFFFF",
        "code": "#F0F0F0"
      },
      "text": {
        "primary": "#1A1A1A",
        "secondary": "#4A5A62",
        "muted": "#7A8A92",
        "placeholder": "#9AA5AD40",
        "disabled": "#9AA5AD80"
      },
      "border": {
        "default": "#D0D0D040",
        "subtle": "#D0D0D030",
        "faint": "#D0D0D020",
        "focused": "#1A1A1A15",
        "divider": "#D0D0D060"
      },
      "interactive": {
        "buttonPrimary": "#1A1A1A",
        "buttonPrimaryText": "#FFFFFF",
        "buttonSecondary": "#F0F0F0",
        "buttonSecondaryText": "#4A5A62",
        "activeHighlight": "#1A1A1A08",
        "hoverHighlight": "#1A1A1A05"
      },
      "shadow": {
        "sm": { "blur": 8, "color": "#00000010", "offsetY": 1 },
        "md": { "blur": 12, "color": "#00000010", "offsetY": 2 },
        "lg": { "blur": 16, "color": "#00000012", "offsetY": 3 },
        "xl": { "blur": 30, "color": "#00000015", "offsetY": 6 }
      }
    }
  },

  "typography": {
    "fontFamily": {
      "display": "Space Grotesk",
      "body": "Manrope",
      "mono": "Space Grotesk"
    },
    "scale": {
      "nodeTitle": { "size": 12, "weight": "500", "font": "Space Grotesk" },
      "nodeContent": { "size": 12, "weight": "normal", "font": "Manrope", "lineHeight": 1.6 },
      "nodeContentTitle": { "size": 15, "weight": "700", "font": "Manrope", "lineHeight": 1.6 },
      "nodeHint": { "size": 11, "weight": "normal", "font": "Manrope" },
      "tag": { "size": 12, "weight": "500", "font": "Manrope" },
      "inputPlaceholder": { "size": 13, "weight": "normal", "font": "Manrope" },
      "chatMessage": { "size": 12, "weight": "normal", "font": "Manrope", "lineHeight": 1.5 },
      "chatTitle": { "size": 13, "weight": "700", "font": "Space Grotesk" },
      "chatSubtitle": { "size": 9, "weight": "500", "font": "Space Grotesk", "letterSpacing": 1 },
      "code": { "size": 10, "weight": "normal", "font": "Space Grotesk", "lineHeight": 1.5 },
      "statusLabel": { "size": 9, "weight": "700", "font": "Space Grotesk", "letterSpacing": 1 },
      "metadata": { "size": 9, "weight": "normal", "font": "Space Grotesk" },
      "templateChip": { "size": 10, "weight": "500", "font": "Manrope" },
      "toolbarLabel": { "size": 11, "weight": "600", "font": "Space Grotesk" }
    }
  },

  "spacing": {
    "nodeCardPadding": [10, 14],
    "nodeContentPadding": [10, 16],
    "panelPadding": [12, 14],
    "chatPadding": [14, 18],
    "tagPadding": [6, 12],
    "chipPadding": [6, 10],
    "toolbarPadding": [4, 8],
    "gap": {
      "nodeItems": 6,
      "tagItems": 8,
      "chatMessages": 16,
      "menuItems": 4,
      "toolbarItems": 2
    }
  },

  "radii": {
    "node": 12,
    "panel": 16,
    "popup": 20,
    "toolbar": 10,
    "menu": 14,
    "tag": 8,
    "button": 8,
    "avatar": 10,
    "chatBubbleUser": [12, 2, 12, 12],
    "chatBubbleAI": [2, 12, 12, 12],
    "inputField": 12
  },

  "iconography": {
    "library": "lucide",
    "nodeIcons": {
      "text": "file-text",
      "image": "image",
      "video": "play-circle",
      "audio": "music"
    },
    "menuIcons": {
      "add": "plus",
      "branch": "git-branch",
      "assets": "package",
      "history": "history",
      "help": "info"
    },
    "actionIcons": {
      "send": "arrow-up",
      "attach": "paperclip",
      "mic": "mic",
      "expand": "maximize-2",
      "grip": "grip-horizontal",
      "edit": "pen-line",
      "close": "x",
      "minimize": "minus"
    },
    "toolbarIcons": {
      "paragraph": "pilcrow",
      "list": "list",
      "orderedList": "list-ordered",
      "horizontalRule": "minus",
      "copy": "copy",
      "fullscreen": "maximize-2"
    },
    "templateIcons": {
      "sparkles": "sparkles",
      "grid": "layout-grid",
      "character": "user",
      "style": "palette",
      "video": "video"
    }
  }
}

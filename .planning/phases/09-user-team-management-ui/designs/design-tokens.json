{
  "$schema": "design-tokens-v1",
  "description": "User & Team Management UI — Design Tokens (extends Phase 08 Admin Console tokens)",
  "source": "pencil-new.pen (Frame r6nJZ — Admin Users Page, Frame i9m7l — Admin Teams Page)",
  "compatibility": "Inherits all Phase 08 Admin Console tokens. Phase 09-specific additions below.",

  "themes": {
    "dark": {
      "semantic": {
        "badge": {
          "active": {
            "bg": "#4CAF5020",
            "text": "#4CAF50"
          },
          "banned": {
            "bg": "#FFB4AB20",
            "text": "#FFB4AB"
          },
          "admin": {
            "bg": "#BB86FC20",
            "text": "#BB86FC"
          }
        },
        "destructive": {
          "bg": "#FFB4AB",
          "text": "#FFB4AB",
          "buttonText": "#131313"
        },
        "modal": {
          "overlay": "#00000080",
          "warningBg": "#FFB4AB10",
          "warningBorder": "#FFB4AB20"
        }
      },
      "interactive": {
        "tableRowHover": "#E5E2E108",
        "sortIndicatorActive": "#E5E2E1",
        "sortIndicatorInactive": "#85939950"
      }
    },

    "light": {
      "semantic": {
        "badge": {
          "active": {
            "bg": "#4CAF5015",
            "text": "#2E7D32"
          },
          "banned": {
            "bg": "#FFB4AB15",
            "text": "#D32F2F"
          },
          "admin": {
            "bg": "#BB86FC15",
            "text": "#7B1FA2"
          }
        },
        "destructive": {
          "bg": "#D32F2F",
          "text": "#D32F2F",
          "buttonText": "#FFFFFF"
        },
        "modal": {
          "overlay": "#00000060",
          "warningBg": "#D32F2F10",
          "warningBorder": "#D32F2F20"
        }
      },
      "interactive": {
        "tableRowHover": "#1A1A1A05",
        "sortIndicatorActive": "#1A1A1A",
        "sortIndicatorInactive": "#7A8A9250"
      }
    }
  },

  "typography": {
    "scale": {
      "pageTitle": { "size": 24, "weight": "700", "font": "Space Grotesk", "lineHeight": 1.2 },
      "pageSubtitle": { "size": 14, "weight": "normal", "font": "Manrope", "lineHeight": 1.5 },
      "tableHeader": { "size": 12, "weight": "700", "font": "Space Grotesk", "lineHeight": 1.3, "letterSpacing": 1, "textTransform": "uppercase" },
      "tableCell": { "size": 12, "weight": "normal", "font": "Manrope", "lineHeight": 1.5 },
      "tableCellBold": { "size": 12, "weight": "700", "font": "Manrope", "lineHeight": 1.5 },
      "badgeLabel": { "size": 12, "weight": "700", "font": "Manrope", "lineHeight": 1.5 },
      "searchPlaceholder": { "size": 12, "weight": "normal", "font": "Manrope", "lineHeight": 1.5 },
      "filterLabel": { "size": 12, "weight": "normal", "font": "Manrope", "lineHeight": 1.5 },
      "dropdownItem": { "size": 12, "weight": "normal", "font": "Manrope", "lineHeight": 1.5 },
      "dropdownItemDanger": { "size": 12, "weight": "normal", "font": "Manrope", "lineHeight": 1.5, "color": "semantic.destructive.text" },
      "modalTitle": { "size": 14, "weight": "700", "font": "Space Grotesk", "lineHeight": 1.3 },
      "modalBody": { "size": 12, "weight": "normal", "font": "Manrope", "lineHeight": 1.5 },
      "modalWarning": { "size": 12, "weight": "700", "font": "Manrope", "lineHeight": 1.5 },
      "paginationText": { "size": 12, "weight": "normal", "font": "Manrope", "lineHeight": 1.5 },
      "paginationNumber": { "size": 12, "weight": "normal", "font": "Manrope", "lineHeight": 1.5 },
      "paginationNumberActive": { "size": 12, "weight": "700", "font": "Manrope", "lineHeight": 1.5 },
      "emptyHeading": { "size": 14, "weight": "700", "font": "Space Grotesk", "lineHeight": 1.3 },
      "emptyBody": { "size": 12, "weight": "normal", "font": "Manrope", "lineHeight": 1.5 }
    }
  },

  "spacing": {
    "mainContentPadding": [32, 40],
    "mainContentGap": 24,
    "toolbarGap": 12,
    "toolbarToTable": 24,
    "tableCellPaddingH": 16,
    "tableCellPaddingV": 12,
    "dimensions": {
      "tableRowHeight": 48,
      "tableHeaderHeight": 40,
      "searchInputHeight": 36,
      "filterDropdownHeight": 36,
      "filterDropdownWidth": 140,
      "dropdownMenuItemHeight": 36,
      "dropdownMenuWidth": 200,
      "confirmModalWidth": 420,
      "badgeHeight": 24,
      "badgePadding": [4, 8],
      "paginationBarHeight": 48,
      "paginationButtonSize": 32,
      "actionButtonSize": [48, 32]
    }
  },

  "radii": {
    "table": 12,
    "badge": 6,
    "searchInput": 8,
    "filterDropdown": 8,
    "dropdownMenu": 8,
    "dropdownItem": 6,
    "modal": 12,
    "modalWarning": 8,
    "paginationButton": 8,
    "destructiveButton": 8,
    "skeletonBar": 6
  },

  "iconography": {
    "library": "lucide",
    "toolbar": {
      "search": "search",
      "filterChevron": "chevron-down"
    },
    "table": {
      "rowActions": "ellipsis",
      "sortAsc": "arrow-up",
      "sortDesc": "arrow-down"
    },
    "dropdown": {
      "ban": "ban",
      "enable": "circle-check",
      "grantAdmin": "shield",
      "revokeAdmin": "shield-off"
    },
    "modal": {
      "ban": "ban",
      "enable": "circle-check",
      "grantAdmin": "shield",
      "revokeAdmin": "shield-off",
      "warning": "alert-triangle"
    },
    "pagination": {
      "prev": "chevron-left",
      "next": "chevron-right"
    },
    "emptyState": {
      "users": "users",
      "teams": "group",
      "noResults": "search",
      "error": "alert-circle"
    }
  },

  "columns": {
    "users": [
      { "key": "name", "header": "NAME", "width": 160, "sortable": false },
      { "key": "email", "header": "EMAIL", "width": 200, "sortable": true, "sortField": "email" },
      { "key": "status", "header": "STATUS", "width": 90, "sortable": false },
      { "key": "admin", "header": "ADMIN", "width": 80, "sortable": false },
      { "key": "teams", "header": "TEAMS", "width": 100, "sortable": false },
      { "key": "last_login", "header": "LAST LOGIN", "width": 120, "sortable": true, "sortField": "last_login_at" },
      { "key": "created", "header": "CREATED", "width": 120, "sortable": true, "sortField": "created_at", "defaultSort": "desc" },
      { "key": "actions", "header": "", "width": 48, "sortable": false }
    ],
    "teams": [
      { "key": "name", "header": "NAME", "width": "fill", "sortable": false },
      { "key": "member_count", "header": "MEMBERS", "width": 120, "sortable": false },
      { "key": "owner", "header": "OWNER", "width": 200, "sortable": false },
      { "key": "created", "header": "CREATED", "width": 160, "sortable": false }
    ]
  },

  "pagination": {
    "defaultPageSize": 20,
    "maxVisiblePages": 5,
    "format": "Showing {start}–{end} of {total} {entity}"
  }
}

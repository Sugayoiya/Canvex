    <!-- ==================== D: TOOL CONTEXT (Purple) ==================== -->
    <mxCell id="grp_ctx" value="D. ToolContext (contextvars)" style="swimlane;startSize=30;fillColor=#E1D5E7;strokeColor=#9673A6;fontStyle=1;fontSize=13;collapsible=0;" vertex="1" parent="1">
      <mxGeometry x="1160" y="100" width="320" height="400" as="geometry"/>
    </mxCell>

    <mxCell id="toolctx" value="&lt;b&gt;@dataclass(frozen=True)&lt;br&gt;ToolContext&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;project_id: str&lt;br&gt;user_id: str&lt;br&gt;team_id: str | None&lt;br&gt;canvas_id: str | None&lt;br&gt;episode_id: str | None&lt;br&gt;session_id: str | None&lt;br&gt;&lt;b&gt;injected_artifacts: dict | None&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;" vertex="1" parent="grp_ctx">
      <mxGeometry x="20" y="45" width="280" height="155" as="geometry"/>
    </mxCell>

    <mxCell id="ctx_funcs" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;set_tool_context()&lt;/b&gt; - kwargs form (agent.py)&lt;br&gt;&lt;b&gt;set_tool_context_obj(ctx)&lt;/b&gt; - object form (interceptor)&lt;br&gt;&lt;b&gt;get_tool_context()&lt;/b&gt; - read from contextvar&lt;br&gt;&lt;b&gt;reset_tool_context(token)&lt;/b&gt; - restore previous&lt;br&gt;&lt;b&gt;clear_tool_context()&lt;/b&gt; - set None (finally)&lt;br&gt;&lt;b&gt;get_context_snapshot()&lt;/b&gt; - cross-task copy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;" vertex="1" parent="grp_ctx">
      <mxGeometry x="20" y="220" width="280" height="100" as="geometry"/>
    </mxCell>

    <mxCell id="ctx_note" value="&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;All 17 tools use get_tool_context()&lt;br&gt;to access project_id, user_id, session_id.&lt;br&gt;Interceptor injects artifacts via&lt;br&gt;dataclasses.replace() + set_tool_context_obj()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8F9;strokeColor=#9673A6;dashed=1;" vertex="1" parent="grp_ctx">
      <mxGeometry x="20" y="335" width="280" height="55" as="geometry"/>
    </mxCell>

    <!-- ==================== E: ARTIFACT STORE (Orange) ==================== -->
    <mxCell id="grp_artifact" value="E. ArtifactStore (PostgreSQL)" style="swimlane;startSize=30;fillColor=#FCE5CD;strokeColor=#D79B00;fontStyle=1;fontSize=13;collapsible=0;" vertex="1" parent="1">
      <mxGeometry x="1160" y="540" width="320" height="340" as="geometry"/>

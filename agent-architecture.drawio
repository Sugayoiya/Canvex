    <mxCell id="celery_img" value="&lt;b&gt;generate_image_task&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;queue: ai_generation&lt;br&gt;max_retries=2, acks_late=True&lt;br&gt;asyncio.wait_for(110s)&lt;br&gt;ProviderManager.get_provider('gemini')&lt;br&gt;&amp;rarr; provider.generate_image()&lt;br&gt;SkillExecutionLog + KeyHealthManager&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;align=left;" vertex="1" parent="grp_celery">

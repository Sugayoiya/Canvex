    <!-- ==================== F: CELERY (Red) ==================== -->
    <mxCell id="grp_celery" value="F. Celery Workers (Redis)" style="swimlane;startSize=30;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;fontSize=13;collapsible=0;" vertex="1" parent="1">
      <mxGeometry x="1160" y="920" width="320" height="260" as="geometry"/>

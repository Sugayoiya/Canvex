      <mxGeometry x="270" y="110" width="220" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="resolve_model" value="&lt;b&gt;resolve_model_for_task()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;4-layer fallback: explicit &amp;rarr; project &amp;rarr;&lt;br&gt;user &amp;rarr; team &amp;rarr; system default&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="grp_http">
      <mxGeometry x="30" y="180" width="220" height="55" as="geometry"/>
    </mxCell>

    <mxCell id="resolve_provider" value="&lt;b&gt;_resolve_provider_with_fallback()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;resolve_provider_for_model&lt;br&gt;via ModelPricing JOIN&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="grp_http">
      <mxGeometry x="270" y="180" width="220" height="55" as="geometry"/>
    </mxCell>

    <mxCell id="sse_stream" value="&lt;b&gt;EventSourceResponse&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;event_generator() async generator&lt;br&gt;sse_protocol.py: THINKING | TOOL_CALL |&lt;br&gt;TOOL_RESULT | TOKEN | DONE | ERROR&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE599;strokeColor=#D6B656;" vertex="1" parent="grp_http">

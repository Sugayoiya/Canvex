    </mxCell>

    <mxCell id="ai_tools" value="&lt;b&gt;AI_TOOLS&lt;/b&gt; (2)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;produces_artifact: True&lt;/font&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;generate_image&lt;br&gt;&amp;nbsp;&amp;nbsp;apply_async &amp;rarr; Celery&lt;br&gt;&amp;nbsp;&amp;nbsp;_poll_celery_result(120s)&lt;br&gt;&lt;br&gt;generate_video&lt;br&gt;&amp;nbsp;&amp;nbsp;apply_async &amp;rarr; Celery&lt;br&gt;&amp;nbsp;&amp;nbsp;_poll_celery_result(300s)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F5E6;strokeColor=#82B366;align=left;verticalAlign=top;" vertex="1" parent="grp_tools">
      <mxGeometry x="400" y="155" width="200" height="175" as="geometry"/>
    </mxCell>

    <mxCell id="skill_tools" value="&lt;b&gt;SKILL_TOOLS&lt;/b&gt; (2)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;produces_artifact: False&lt;/font&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;read_skill(name)&lt;br&gt;&amp;nbsp;&amp;nbsp;skills/{name}/SKILL.md&lt;br&gt;&lt;br&gt;read_resource(name, filename)&lt;br&gt;&amp;nbsp;&amp;nbsp;100KB limit&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F5E6;strokeColor=#82B366;align=left;verticalAlign=top;" vertex="1" parent="grp_tools">
      <mxGeometry x="620" y="155" width="200" height="175" as="geometry"/>
    </mxCell>

    <!-- ToolInterceptor box -->
    <mxCell id="interceptor" value="&lt;b&gt;ToolInterceptor&lt;/b&gt; (tool_interceptor.py)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;wrap_tool_with_interceptor(tool, TOOL_METADATA, all_tools)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B6D7A8;strokeColor=#82B366;fontStyle=0;" vertex="1" parent="grp_tools">
      <mxGeometry x="20" y="355" width="800" height="35" as="geometry"/>
    </mxCell>

    <mxCell id="before_hook" value="&lt;b&gt;Before-Hook&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;if require_prior_kind + session_id:&lt;br&gt;_inject_dependencies() &amp;rarr; ArtifactStore.get_latest_payload()&lt;br&gt;replace(ctx, injected_artifacts={...}) &amp;rarr; set_tool_context_obj()&lt;br&gt;Recursive backfill (max depth 3) with _can_backfill_without_input()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#82B366;align=left;" vertex="1" parent="grp_tools">
      <mxGeometry x="20" y="410" width="390" height="85" as="geometry"/>
    </mxCell>

    <mxCell id="after_hook" value="&lt;b&gt;After-Hook&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;if produces_artifact + session_id + no error:&lt;br&gt;_parse_tool_result() &amp;rarr; generate_summary()&lt;br&gt;ArtifactStoreService.save() &amp;rarr; {summary, artifact_id}&lt;br&gt;Extracts log_id for execution_log_id FK&lt;br&gt;reset_tool_context(token) in finally block&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#82B366;align=left;" vertex="1" parent="grp_tools">

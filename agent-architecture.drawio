    <!-- Tool registry box -->
    <mxCell id="tool_registry" value="&lt;b&gt;tools/__init__.py&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;TOOL_METADATA (17 entries): skill_kind, context_group,&lt;br&gt;produces_artifact, is_read_only, timeout, ...&lt;br&gt;&lt;br&gt;&lt;b&gt;get_all_tools()&lt;/b&gt; &amp;rarr; _attach_tool_metadata &amp;rarr; wrap_tool_with_interceptor&lt;br&gt;&lt;b&gt;get_tools_for_context()&lt;/b&gt; &amp;rarr; tool_middleware filter by context_group&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="grp_tools">

    <!-- ==================== C: TOOL SYSTEM (Green) ==================== -->
    <mxCell id="grp_tools" value="C. Tool System (17 Tools + Interceptor)" style="swimlane;startSize=30;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontSize=13;collapsible=0;" vertex="1" parent="1">
      <mxGeometry x="40" y="540" width="1080" height="520" as="geometry"/>

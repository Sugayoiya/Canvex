    <!-- 4 tool categories -->
    <mxCell id="ctx_tools" value="&lt;b&gt;CONTEXT_TOOLS&lt;/b&gt; (7)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;produces_artifact: False&lt;/font&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;get_project_info&lt;br&gt;get_episodes&lt;br&gt;get_characters&lt;br&gt;get_scenes&lt;br&gt;get_script&lt;br&gt;get_canvas_state&lt;br&gt;get_style_templates&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F5E6;strokeColor=#82B366;align=left;verticalAlign=top;" vertex="1" parent="grp_tools">
      <mxGeometry x="20" y="155" width="170" height="175" as="geometry"/>
    </mxCell>

    <mxCell id="mut_tools" value="&lt;b&gt;MUTATION_TOOLS&lt;/b&gt; (6)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;produces_artifact: True&lt;/font&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;save_characters&lt;br&gt;save_scenes&lt;br&gt;save_screenplay&lt;br&gt;save_shot_plan&lt;br&gt;save_shot_details&lt;br&gt;update_shot&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F5E6;strokeColor=#82B366;align=left;verticalAlign=top;" vertex="1" parent="grp_tools">

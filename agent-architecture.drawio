    <mxCell id="http_entry" value="&lt;b&gt;POST /api/v1/agent/chat/{session_id}&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;body: ChatRequest(message, model_name, provider)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE599;strokeColor=#D6B656;" vertex="1" parent="grp_http">

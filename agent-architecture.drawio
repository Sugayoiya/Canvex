    <mxCell id="langchain_agent" value="&lt;b&gt;langchain.agents.create_agent(llm, tools, system_prompt)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Returns CompiledStateGraph&lt;br&gt;supports astream_events(v2) / ainvoke&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCE5FF;strokeColor=#6C8EBF;fontStyle=0;" vertex="1" parent="grp_agent">

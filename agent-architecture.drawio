    </mxCell>

    <mxCell id="artifact_svc" value="&lt;b&gt;ArtifactStoreService&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;save(session_id, skill_kind, summary, payload, log_id)&lt;br&gt;get_latest(session_id, skill_kind)&lt;br&gt;get_latest_payload(session_id, skill_kind)&lt;br&gt;list_session_artifacts(session_id)&lt;/font&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;generate_summary()&lt;/b&gt;&lt;br&gt;8 SUMMARY_TEMPLATES (save_characters,&lt;br&gt;scenes, screenplay, shot_plan, ...&lt;br&gt;generate_image, generate_video)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE5CD;strokeColor=#D79B00;align=left;" vertex="1" parent="grp_artifact">
      <mxGeometry x="20" y="210" width="280" height="120" as="geometry"/>

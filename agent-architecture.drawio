    <mxCell id="artifact_model" value="&lt;b&gt;AgentArtifact&lt;/b&gt; (agent_artifacts)&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;id: UUID PK&lt;br&gt;session_id: FK &amp;rarr; agent_sessions (CASCADE)&lt;br&gt;skill_kind: VARCHAR(100)&lt;br&gt;summary: TEXT (&amp;le;500 chars)&lt;br&gt;payload: JSONB&lt;br&gt;execution_log_id: FK &amp;rarr; skill_execution_logs&lt;br&gt;created_at: TZDateTime&lt;/font&gt;&lt;hr&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Indexes: (session_id, skill_kind), (session_id, created_at)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE5CD;strokeColor=#D79B00;align=left;" vertex="1" parent="grp_artifact">
